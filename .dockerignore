# Build context is the repository root. Keep what the image needs (Project.toml, Manifest.toml,
# packages/, the lib/ runtime submodule, docker/, config/) and drop everything else, especially the
# large submodule .git dirs.

**/.git
**/.gitignore

# Not needed in the image. **/test/ drops the per-package test trees under packages/*/test/
# (e.g. the large e2e weights) from `COPY packages/`.
bundles/
validation/
test/
**/test/
examples/
tools/
proto_src/
*.md
**/*.md

# Offline export tooling that is not a server runtime dependency (not a workspace member, so the
# worker's `COPY packages/` would otherwise pull it in).
packages/ReactantServerExport/

# Python / editor / cache cruft.
**/.CondaPkg/
**/.venv/
**/__pycache__/
**/*.pyc
.idea/
