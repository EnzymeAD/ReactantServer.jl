{
  "uid": "rs-model-drilldown",
  "title": "ReactantServer / Per-Model Drilldown",
  "tags": ["reactantserver", "model"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      { "name": "model", "label": "Model", "type": "query", "datasource": { "type": "prometheus", "uid": "prometheus" }, "query": { "query": "label_values(worker_model_weight_bytes, model)", "refId": "model" }, "refresh": 2, "sort": 1, "includeAll": false, "multi": false }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Requests / s",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(gateway_requests_total{model=~\"$model\"}[$__rate_interval]))" } ]
    },
    {
      "type": "stat",
      "title": "Error rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "background" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(gateway_requests_total{model=~\"$model\", status!=\"OK\"}[$__rate_interval])) / clamp_min(sum(rate(gateway_requests_total{model=~\"$model\"}[$__rate_interval])), 1e-9)" } ]
    },
    {
      "type": "stat",
      "title": "Resident on (workers)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(worker_model_resident{model=~\"$model\"})" } ]
    },
    {
      "type": "stat",
      "title": "Weight footprint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(worker_model_weight_bytes{model=~\"$model\"})" } ]
    },
    {
      "type": "heatmap",
      "title": "Handler latency distribution - $model",
      "description": "Worker-side ModelInfer latency distribution for this model, from its histogram buckets.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "options": { "calculate": false, "cellGap": 1, "color": { "mode": "scheme", "scheme": "Spectral", "reverse": true, "steps": 64 }, "yAxis": { "unit": "s" }, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (le) (rate(worker_request_latency_seconds_bucket{model=~\"$model\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Queue depth & wait - $model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 8 } }, "overrides": [ { "matcher": { "id": "byRegexp", "options": ".*wait.*" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "custom.axisPlacement", "value": "right" } ] }, { "matcher": { "id": "byRegexp", "options": ".*depth.*" }, "properties": [ { "id": "unit", "value": "short" } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (worker) (worker_queue_depth{model=~\"$model\"})", "legendFormat": "depth {{worker}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(worker_queue_wait_seconds{model=~\"$model\", quantile=\"0.99\"})", "legendFormat": "wait p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Coalescing - $model (requests & rows/dispatch)",
      "description": "This model's request rate vs its coalescing factor (served rows per dispatch). Low traffic + low coalescing = it pays cold loads often.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 6 } }, "overrides": [ { "matcher": { "id": "byName", "options": "req/s" }, "properties": [ { "id": "unit", "value": "reqps" } ] }, { "matcher": { "id": "byName", "options": "rows/dispatch" }, "properties": [ { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(worker_requests_total{model=~\"$model\", status=\"OK\"}[$__rate_interval]))", "legendFormat": "req/s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(worker_requests_total{model=~\"$model\", status=\"OK\"}[$__rate_interval])) / clamp_min(sum(rate(worker_dispatch_total{model=~\"$model\"}[$__rate_interval])), 1e-9)", "legendFormat": "rows/dispatch" }
      ]
    },
    {
      "type": "state-timeline",
      "title": "Residency by worker - $model",
      "description": "Where this model is device-resident over time. Gaps after a compaction flush or an eviction; it re-warms on the next request.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "dark-red", "value": null }, { "color": "green", "value": 1 } ] }, "mappings": [ { "type": "value", "options": { "0": { "text": "evicted", "color": "dark-red" }, "1": { "text": "resident", "color": "green" } } } ], "max": 1, "min": 0 } },
      "options": { "showValue": "never", "mergeValues": true, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "worker_model_resident{model=~\"$model\"}", "legendFormat": "{{worker}}" } ]
    },
    {
      "type": "table",
      "title": "Placement - $model",
      "description": "Which worker(s) the gateway routes this model to (host:port), and the sampling weight.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "align": "auto" } } },
      "options": { "showHeader": true },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "gateway_placement_weight{model=~\"$model\"} > 0", "format": "table", "instant": true } ],
      "transformations": [ { "id": "organize", "options": { "excludeByName": { "Time": true, "model": true, "__name__": true, "job": true, "instance": true, "node": true, "deployment": true }, "renameByName": { "Value": "weight" } } } ]
    }
  ]
}
